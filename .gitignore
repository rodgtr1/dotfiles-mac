# macOS
.DS_Store

# Raycast: only keep custom extensions (mine); ignore Store-installed ones,
# node_modules symlink, caches and logs.
raycast/.config/raycast/extensions/*
!raycast/.config/raycast/extensions/income-calculator
raycast/.config/raycast/cache/
raycast/.config/raycast/**/*.log

# Neovim runtime state
nvim/.config/nvim/.netrwhist

# Never commit secrets — keep these out even if a package ever includes them
**/sops/age/keys.txt
**/gh/hosts.yml
