# macOS
.DS_Store

# Raycast app state / installed deps (not real config)
# node_modules is a symlink into Raycast.app — machine-specific
raycast/.config/raycast/extensions/node_modules
raycast/.config/raycast/cache/
raycast/.config/raycast/**/*.log

# Neovim runtime state
nvim/.config/nvim/.netrwhist

# Never commit secrets — keep these out even if a package ever includes them
**/sops/age/keys.txt
**/gh/hosts.yml
